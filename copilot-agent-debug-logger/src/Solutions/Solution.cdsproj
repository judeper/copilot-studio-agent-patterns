<Project Sdk="Microsoft.PowerApps.MSBuild.Solution/1.0.6">
  <PropertyGroup>
    <SolutionPackageType>Unmanaged</SolutionPackageType>
    <SolutionUniqueName>CopilotAgentDebugLogger</SolutionUniqueName>
    <SolutionVersion>1.0.0</SolutionVersion>
    <SolutionLocalizedName>Copilot Agent Debug Logger</SolutionLocalizedName>
    <SolutionDescription>Maker-focused POC that captures Power Automate ↔ Copilot Studio request/response payloads with shared correlation IDs.</SolutionDescription>
    <OutputPath>$(MSBuildThisFileDirectory)bin\Debug</OutputPath>
  </PropertyGroup>
  <Target Name="BeforeBuild" />
  <Target Name="AfterBuild" />
  <Target Name="Build" DependsOnTargets="BeforeBuild;AfterBuild" />
</Project>
