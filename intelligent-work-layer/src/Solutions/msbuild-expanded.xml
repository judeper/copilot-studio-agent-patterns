  <PropertyGroup>
    <SolutionPackageType>Unmanaged</SolutionPackageType>
    <SolutionUniqueName>EnterpriseWorkAssistant</SolutionUniqueName>
    <SolutionVersion>1.0.0</SolutionVersion>
    <SolutionLocalizedName>Intelligent Work Layer</SolutionLocalizedName>
    <SolutionDescription>PCF dashboard component for the Intelligent Work Layer agent.</SolutionDescription>
    <OutputPath>$(MSBuildThisFileDirectory)bin\Debug</OutputPath>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\AssistantDashboard.pcfproj" />
  </ItemGroup>
