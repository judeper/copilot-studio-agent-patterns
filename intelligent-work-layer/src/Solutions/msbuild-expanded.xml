  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|AnyCPU'" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <OutputPath Condition="'$(OutputPath)' == ''">bin\Debug\</OutputPath>
