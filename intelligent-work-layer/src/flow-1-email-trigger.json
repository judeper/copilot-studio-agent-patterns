{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "triggers": {
      "When_a_new_email_arrives_(V3)": {
        "type": "OpenApiConnectionNotification",
        "inputs": {
          "parameters": {
            "$connections": {
              "defaultValue": {},
              "type": "Object"
            },
            "$authentication": {
              "defaultValue": {},
              "type": "SecureObject"
            },
            "folderPath": "Inbox",
            "importance": "Any",
            "fetchOnlyWithAttachment": false,
            "includeAttachments": false
          },
          "host": {
            "operationId": "OnNewEmailV3",
            "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365",
            "connectionName": "shared_office365"
          },
          "authentication": "@parameters('$authentication')"
        },
        "splitOn": "@triggerBody()?['value']"
      }
    },
    "actions": {
      "Scope_Process_Email": {
        "type": "Scope",
        "actions": {
          "Get_email_(V2)": {
            "type": "OpenApiConnection",
            "inputs": {
              "parameters": {
                "$connections": {
                  "defaultValue": {},
                  "type": "Object"
                },
                "$authentication": {
                  "defaultValue": {},
                  "type": "SecureObject"
                },
                "messageId": "@triggerOutputs()?['body/id']"
              },
              "host": {
                "operationId": "GetEmailV2",
                "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365",
                "connectionName": "shared_office365"
              },
              "authentication": "@parameters('$authentication')"
            },
            "runAfter": {}
          },
          "Get_my_profile_(V2)": {
            "type": "OpenApiConnection",
            "inputs": {
              "parameters": {
                "$connections": {
                  "defaultValue": {},
                  "type": "Object"
                },
                "$authentication": {
                  "defaultValue": {},
                  "type": "SecureObject"
                }
              },
              "host": {
                "operationId": "MyProfile_V2",
                "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365users",
                "connectionName": "shared_office365users"
              },
              "authentication": "@parameters('$authentication')"
            },
            "runAfter": {
              "Get_email_(V2)": [
                "Succeeded"
              ]
            }
          },
          "Condition_Skip_NoReply": {
            "type": "If",
            "expression": {
              "or": [
                {
                  "contains": [
                    "@toLower(outputs('Get_email_(V2)')?['body/from'])",
                    "noreply"
                  ]
                },
                {
                  "contains": [
                    "@toLower(outputs('Get_email_(V2)')?['body/from'])",
                    "no-reply"
                  ]
                },
                {
                  "contains": [
                    "@toLower(outputs('Get_email_(V2)')?['body/from'])",
                    "mailer-daemon"
                  ]
                }
              ]
            },
            "actions": {
              "Terminate_NoReply": {
                "type": "Terminate",
                "inputs": {
                  "runStatus": "Succeeded"
                }
              }
            },
            "else": {
              "actions": {}
            },
            "runAfter": {
              "Get_my_profile_(V2)": [
                "Succeeded"
              ]
            }
          },
          "Condition_Skip_LowImportance": {
            "type": "If",
            "expression": {
              "and": [
                {
                  "equals": [
                    "@outputs('Get_email_(V2)')?['body/importance']",
                    "low"
                  ]
                }
              ]
            },
            "actions": {
              "Terminate_LowImportance": {
                "type": "Terminate",
                "inputs": {
                  "runStatus": "Succeeded"
                }
              }
            },
            "else": {
              "actions": {}
            },
            "runAfter": {
              "Condition_Skip_NoReply": [
                "Succeeded"
              ]
            }
          },
          "Compose_SenderEmail": {
            "type": "Compose",
            "inputs": "@outputs('Get_email_(V2)')?['body/from']",
            "runAfter": {
              "Condition_Skip_LowImportance": [
                "Succeeded"
              ]
            }
          },
          "List_SenderProfile": {
            "type": "OpenApiConnection",
            "inputs": {
              "parameters": {
                "$connections": {
                  "defaultValue": {},
                  "type": "Object"
                },
                "$authentication": {
                  "defaultValue": {},
                  "type": "SecureObject"
                },
                "entityName": "cr_senderprofiles",
                "$filter": "cr_senderemail eq '@{outputs('Compose_SenderEmail')}'",
                "$top": 1
              },
              "host": {
                "operationId": "ListRecords",
                "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                "connectionName": "shared_commondataserviceforapps"
              },
              "authentication": "@parameters('$authentication')"
            },
            "runAfter": {
              "Compose_SenderEmail": [
                "Succeeded"
              ]
            }
          },
          "Compose_SenderProfile": {
            "type": "Compose",
            "inputs": "@if(greater(length(outputs('List_SenderProfile')?['body/value']), 0), string(first(outputs('List_SenderProfile')?['body/value'])), 'null')",
            "runAfter": {
              "List_SenderProfile": [
                "Succeeded"
              ]
            }
          },
          "Compose_AgentPayload": {
            "type": "Compose",
            "inputs": {
              "TRIGGER_TYPE": "EMAIL",
              "PAYLOAD": {
                "from": "@outputs('Get_email_(V2)')?['body/from']",
                "to": "@outputs('Get_email_(V2)')?['body/toRecipients']",
                "cc": "@outputs('Get_email_(V2)')?['body/ccRecipients']",
                "subject": "@outputs('Get_email_(V2)')?['body/subject']",
                "bodyPreview": "@outputs('Get_email_(V2)')?['body/bodyPreview']",
                "receivedDateTime": "@outputs('Get_email_(V2)')?['body/receivedDateTime']",
                "importance": "@outputs('Get_email_(V2)')?['body/importance']",
                "hasAttachments": "@outputs('Get_email_(V2)')?['body/hasAttachments']",
                "conversationId": "@outputs('Get_email_(V2)')?['body/conversationId']",
                "internetMessageId": "@outputs('Get_email_(V2)')?['body/internetMessageId']"
              },
              "USER_CONTEXT": {
                "userId": "@outputs('Get_my_profile_(V2)')?['body/id']",
                "userEmail": "@outputs('Get_my_profile_(V2)')?['body/mail']",
                "userDisplayName": "@outputs('Get_my_profile_(V2)')?['body/displayName']",
                "userDomain": "@split(outputs('Get_my_profile_(V2)')?['body/mail'], '@')[1]"
              },
              "CURRENT_DATETIME": "@utcNow()",
              "SENDER_PROFILE": "@outputs('Compose_SenderProfile')"
            },
            "runAfter": {
              "Compose_SenderProfile": [
                "Succeeded"
              ]
            }
          },
          "Execute_EWA_Agent": {
            "type": "OpenApiConnection",
            "inputs": {
              "parameters": {
                "$connections": {
                  "defaultValue": {},
                  "type": "Object"
                },
                "$authentication": {
                  "defaultValue": {},
                  "type": "SecureObject"
                },
                "botId": "<ewa-agent-schema-name>",
                "message": "@{string(outputs('Compose_AgentPayload'))}"
              },
              "host": {
                "operationId": "ExecuteAgentAndWait",
                "apiId": "/providers/Microsoft.PowerApps/apis/shared_microsoftcopilotstudio",
                "connectionName": "shared_microsoftcopilotstudio"
              },
              "retryPolicy": {
                "type": "exponential",
                "count": 2,
                "interval": "PT15S"
              },
              "authentication": "@parameters('$authentication')"
            },
            "runAfter": {
              "Compose_AgentPayload": [
                "Succeeded"
              ]
            }
          },
          "Parse_Agent_Response": {
            "type": "ParseJson",
            "inputs": {
              "content": "@{outputs('Execute_EWA_Agent')?['body/lastResponse']}",
              "schema": {
                "type": "object",
                "properties": {
                  "triage_tier": {
                    "type": "string"
                  },
                  "item_summary": {
                    "type": "string"
                  },
                  "priority": {
                    "type": "string"
                  },
                  "temporal_horizon": {
                    "type": "string"
                  },
                  "confidence_score": {
                    "type": "integer"
                  },
                  "card_status": {
                    "type": "string"
                  },
                  "trigger_type": {
                    "type": "string"
                  },
                  "original_sender_email": {
                    "type": "string"
                  },
                  "original_sender_display": {
                    "type": "string"
                  },
                  "original_subject": {
                    "type": "string"
                  },
                  "conversation_cluster_id": {
                    "type": "string"
                  },
                  "source_signal_id": {
                    "type": "string"
                  },
                  "full_json": {
                    "type": "string"
                  },
                  "draft_payload": {
                    "type": "object"
                  }
                }
              }
            },
            "runAfter": {
              "Execute_EWA_Agent": [
                "Succeeded"
              ]
            }
          },
          "Condition_Not_Skip": {
            "type": "If",
            "expression": {
              "and": [
                {
                  "not": {
                    "equals": [
                      "@body('Parse_Agent_Response')?['triage_tier']",
                      "SKIP"
                    ]
                  }
                }
              ]
            },
            "actions": {
              "Create_AssistantCard": {
                "type": "OpenApiConnection",
                "inputs": {
                  "parameters": {
                    "$connections": {
                      "defaultValue": {},
                      "type": "Object"
                    },
                    "$authentication": {
                      "defaultValue": {},
                      "type": "SecureObject"
                    },
                    "entityName": "cr_assistantcards",
                    "item/cr_itemsummary": "@take(coalesce(body('Parse_Agent_Response')?['item_summary'], ''), 300)",
                    "item/cr_triagetier": "@if(equals(body('Parse_Agent_Response')?['triage_tier'], 'FULL'), 100000002, if(equals(body('Parse_Agent_Response')?['triage_tier'], 'LIGHT'), 100000001, 100000000))",
                    "item/cr_triggertype": 100000000,
                    "item/cr_priority": "@if(equals(body('Parse_Agent_Response')?['priority'], 'High'), 100000000, if(equals(body('Parse_Agent_Response')?['priority'], 'Medium'), 100000001, if(equals(body('Parse_Agent_Response')?['priority'], 'Low'), 100000002, 100000003)))",
                    "item/cr_cardstatus": "@if(equals(body('Parse_Agent_Response')?['card_status'], 'READY'), 100000000, if(equals(body('Parse_Agent_Response')?['card_status'], 'LOW_CONFIDENCE'), 100000001, if(equals(body('Parse_Agent_Response')?['card_status'], 'SUMMARY_ONLY'), 100000002, 100000003)))",
                    "item/cr_temporalhorizon": "@if(equals(body('Parse_Agent_Response')?['temporal_horizon'], 'TODAY'), 100000000, if(equals(body('Parse_Agent_Response')?['temporal_horizon'], 'THIS_WEEK'), 100000001, if(equals(body('Parse_Agent_Response')?['temporal_horizon'], 'NEXT_WEEK'), 100000002, if(equals(body('Parse_Agent_Response')?['temporal_horizon'], 'BEYOND'), 100000003, 100000004))))",
                    "item/cr_confidencescore": "@body('Parse_Agent_Response')?['confidence_score']",
                    "item/cr_fulljson": "@coalesce(body('Parse_Agent_Response')?['full_json'], string(body('Parse_Agent_Response')))",
                    "item/cr_originalsenderemail": "@body('Parse_Agent_Response')?['original_sender_email']",
                    "item/cr_originalsenderdisplay": "@body('Parse_Agent_Response')?['original_sender_display']",
                    "item/cr_originalsubject": "@body('Parse_Agent_Response')?['original_subject']",
                    "item/cr_conversationclusterid": "@outputs('Get_email_(V2)')?['body/conversationId']",
                    "item/cr_sourcesignalid": "@outputs('Get_email_(V2)')?['body/internetMessageId']",
                    "item/cr_cardoutcome": 100000000,
                    "item/ownerid": "@outputs('Get_my_profile_(V2)')?['body/id']"
                  },
                  "host": {
                    "operationId": "CreateRecord",
                    "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                    "connectionName": "shared_commondataserviceforapps"
                  },
                  "authentication": "@parameters('$authentication')"
                },
                "runAfter": {}
              },
              "Condition_Humanizer": {
                "type": "If",
                "expression": {
                  "and": [
                    {
                      "equals": [
                        "@body('Parse_Agent_Response')?['triage_tier']",
                        "FULL"
                      ]
                    },
                    {
                      "greaterOrEquals": [
                        "@body('Parse_Agent_Response')?['confidence_score']",
                        40
                      ]
                    }
                  ]
                },
                "actions": {
                  "Compose_HumanizerInput": {
                    "type": "Compose",
                    "inputs": {
                      "draft_payload": "@body('Parse_Agent_Response')?['draft_payload']",
                      "original_subject": "@body('Parse_Agent_Response')?['original_subject']",
                      "original_sender_display": "@body('Parse_Agent_Response')?['original_sender_display']",
                      "triage_tier": "@body('Parse_Agent_Response')?['triage_tier']",
                      "item_summary": "@body('Parse_Agent_Response')?['item_summary']"
                    },
                    "runAfter": {}
                  },
                  "Execute_Humanizer_Agent": {
                    "type": "OpenApiConnection",
                    "inputs": {
                      "parameters": {
                        "$connections": {
                          "defaultValue": {},
                          "type": "Object"
                        },
                        "$authentication": {
                          "defaultValue": {},
                          "type": "SecureObject"
                        },
                        "botId": "<humanizer-agent-schema-name>",
                        "message": "@{string(outputs('Compose_HumanizerInput'))}"
                      },
                      "host": {
                        "operationId": "ExecuteAgentAndWait",
                        "apiId": "/providers/Microsoft.PowerApps/apis/shared_microsoftcopilotstudio",
                        "connectionName": "shared_microsoftcopilotstudio"
                      },
                      "retryPolicy": {
                        "type": "exponential",
                        "count": 2,
                        "interval": "PT15S"
                      },
                      "authentication": "@parameters('$authentication')"
                    },
                    "runAfter": {
                      "Compose_HumanizerInput": [
                        "Succeeded"
                      ]
                    }
                  },
                  "Update_Card_Humanized": {
                    "type": "OpenApiConnection",
                    "inputs": {
                      "parameters": {
                        "$connections": {
                          "defaultValue": {},
                          "type": "Object"
                        },
                        "$authentication": {
                          "defaultValue": {},
                          "type": "SecureObject"
                        },
                        "entityName": "cr_assistantcards",
                        "recordId": "@outputs('Create_AssistantCard')?['body/cr_assistantcardid']",
                        "item/cr_humanizeddraft": "@outputs('Execute_Humanizer_Agent')?['body/lastResponse']"
                      },
                      "host": {
                        "operationId": "UpdateRecord",
                        "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                        "connectionName": "shared_commondataserviceforapps"
                      },
                      "authentication": "@parameters('$authentication')"
                    },
                    "runAfter": {
                      "Execute_Humanizer_Agent": [
                        "Succeeded"
                      ]
                    }
                  }
                },
                "else": {
                  "actions": {}
                },
                "runAfter": {
                  "Create_AssistantCard": [
                    "Succeeded"
                  ]
                }
              }
            },
            "else": {
              "actions": {}
            },
            "runAfter": {
              "Parse_Agent_Response": [
                "Succeeded"
              ]
            }
          },
          "Upsert_SenderProfile": {
            "type": "OpenApiConnection",
            "inputs": {
              "parameters": {
                "$connections": {
                  "defaultValue": {},
                  "type": "Object"
                },
                "$authentication": {
                  "defaultValue": {},
                  "type": "SecureObject"
                },
                "entityName": "cr_senderprofiles",
                "recordId": "@if(greater(length(outputs('List_SenderProfile')?['body/value']), 0), first(outputs('List_SenderProfile')?['body/value'])?['cr_senderprofileid'], null)",
                "item/cr_senderemail": "@outputs('Compose_SenderEmail')",
                "item/cr_senderdisplayname": "@coalesce(outputs('Get_email_(V2)')?['body/sender']?['emailAddress']?['name'], outputs('Compose_SenderEmail'))",
                "item/cr_signalcount": "@if(greater(length(outputs('List_SenderProfile')?['body/value']), 0), add(first(outputs('List_SenderProfile')?['body/value'])?['cr_signalcount'], 1), 1)",
                "item/cr_lastsignaldate": "@utcNow()",
                "item/cr_isinternal": "@contains(toLower(outputs('Compose_SenderEmail')), toLower(split(outputs('Get_my_profile_(V2)')?['body/mail'], '@')[1]))"
              },
              "host": {
                "operationId": "UpdateRecord",
                "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps",
                "connectionName": "shared_commondataserviceforapps"
              },
              "authentication": "@parameters('$authentication')"
            },
            "runAfter": {
              "Condition_Not_Skip": [
                "Succeeded"
              ]
            }
          }
        },
        "runAfter": {}
      },
      "Scope_Handle_Errors": {
        "type": "Scope",
        "actions": {
          "Compose_ErrorDetails": {
            "type": "Compose",
            "inputs": {
              "flowName": "IWL-Flow-1-EmailTrigger",
              "errorTimestamp": "@utcNow()",
              "triggerSubject": "@coalesce(triggerOutputs()?['body/subject'], 'Unknown')",
              "triggerFrom": "@coalesce(triggerOutputs()?['body/from'], 'Unknown')",
              "errorMessage": "Email trigger flow failed during processing. Check run history for details."
            },
            "runAfter": {}
          }
        },
        "runAfter": {
          "Scope_Process_Email": [
            "Failed",
            "TimedOut"
          ]
        }
      }
    }
  }
}